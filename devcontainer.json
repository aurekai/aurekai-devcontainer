{
  "name": "Aurekai Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "postCreateCommand": "bash scripts/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.vscode-json",
        "redhat.vscode-yaml"
      ]
    }
  },
  "remoteEnv": {
    "AUREKAI_VERSION": "0.8.0-alpha.4",
    "AUREKAI_MANIFEST_SCHEMA": "aurekai.deploy.v1"
  },
  "mounts": [],
  "forwardPorts": []
}